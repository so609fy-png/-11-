# Задача 1. 28n + 30k + 31m = 365
# n, k, m - натуральные числа (>=1)

print("Задача 1. Решения уравнения 28n + 30k + 31m = 365")
print("n (28 дней)  k (30 дней)  m (31 день)")

for n in range(1, 14):  # 28*13 = 364, максимум 13
    for k in range(1, 13):  # 30*12 = 360
        for m in range(1, 12):  # 31*11 = 341
            if 28 * n + 30 * k + 31 * m == 365:
                print(f"     {n}           {k}           {m}")


      
